# Copy to .env for local development. docker-compose reads this file directly;
# the app also loads it via pydantic-settings (see src/app/config.py).
#
# NOTE: when running the app itself *inside* docker-compose, DATABASE_URL is
# overridden in docker-compose.yml to point at the "postgres" service hostname
# instead of localhost -- this file's value is for running the app on the host
# against the dockerised Postgres exposed on 5432.

ENVIRONMENT=local
LOG_LEVEL=INFO

# TfL Unified API app key -- register at https://api-portal.tfl.gov.uk/
TFL_APP_KEY=changeme

DATABASE_URL=postgresql+psycopg://tfl:tfl@localhost:5432/tfl_disruption_history
